<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- ADD-18: dictation/voice notes capture the microphone through WKWebView's
       getUserMedia. The release build is signed with the hardened runtime, which
       BLOCKS microphone access unless this entitlement is present — the
       NSMicrophoneUsageDescription string and the user's Privacy toggle are
       necessary but not sufficient on their own. Audio is transcribed on-device
       and never leaves the Mac. -->
  <key>com.apple.security.device.audio-input</key>
  <true/>
</dict>
</plist>
