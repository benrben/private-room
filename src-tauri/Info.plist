<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Re-declares the .roomai association from tauri.conf.json so the
       document icon (bundled via resources) can be attached; user-supplied
       plist keys take precedence over the generated ones. -->
  <key>CFBundleDocumentTypes</key>
  <array>
    <dict>
      <key>CFBundleTypeExtensions</key>
      <array>
        <string>roomai</string>
      </array>
      <key>CFBundleTypeName</key>
      <string>Private Room Project</string>
      <key>CFBundleTypeRole</key>
      <string>Editor</string>
      <key>CFBundleTypeIconFile</key>
      <string>document.icns</string>
    </dict>
  </array>
</dict>
</plist>
