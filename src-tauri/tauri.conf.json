{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Private Room",
  "version": "0.1.0",
  "identifier": "com.benreich.privateroom",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Private Room",
        "width": 1180,
        "height": 780,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "fileAssociations": [
      {
        "ext": ["roomai"],
        "name": "Private Room Project",
        "description": "Private Room encrypted AI workspace",
        "role": "Editor"
      }
    ],
    "resources": {
      "icons/document.icns": "document.icns"
    },
    "macOS": {
      "signingIdentity": "-",
      "dmg": {
        "background": "./dmg-background.tiff",
        "windowSize": { "width": 660, "height": 400 },
        "appPosition": { "x": 170, "y": 230 },
        "applicationFolderPosition": { "x": 490, "y": 230 }
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/benreich/private-room/releases/latest/download/latest.json"
      ],
      "pubkey": "REPLACE_WITH_UPDATER_PUBLIC_KEY"
    }
  }
}
